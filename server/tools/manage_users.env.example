# manage_users.env — Configuração para manage_users.py
# Copie este arquivo para manage_users.env e ajuste os valores.
# O script carrega este arquivo automaticamente se estiver no mesmo diretório.
# Argumentos CLI sobrescrevem os valores aqui definidos.
#
# ATENÇÃO: Não commite manage_users.env (contém caminho da chave SSH).
#          Apenas manage_users.env.example deve estar no repositório.

# Banco local (backup)
LOCAL_DB=~/.cache/studyamigo/20260330/admin.db
LOCAL_USERDB=~/.cache/studyamigo/20260330/user_dbs/
LOCAL_SESSION=server/flask_session/

# Produção (EC2)
PROD_HOST=54.152.109.26
PROD_USER=ubuntu
PROD_KEY=~/.ssh/study-amigo-aws
PROD_DB=/opt/study-amigo/server/admin.db
PROD_USERDB=/opt/study-amigo/server/user_dbs/
PROD_SESSION=/opt/study-amigo/server/flask_session/
